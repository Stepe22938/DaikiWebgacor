# ==========================================
# Environment Variables Example (Local Run)
# ==========================================

# Database Configuration (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daikiweb

# Clerk Authentication Configuration
# Get these from your Clerk Dashboard (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Frontend Clerk Configuration (Must match CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Music Search / Full Song Playback (YouTube Data API v3)
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key_here
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/api/music/spotify/callback

# Optional Port Overrides (default backend: 5000, frontend: 5173)
PORT=5000
BASE_PATH=/

# AI Provider Configuration
# Uses an OpenAI-compatible /v1/chat/completions API.
# Set AI_PROVIDER=obscuraworks to route Zaidan AI through ObscuraWorks.
AI_PROVIDER=obscuraworks
OBSCURAWORKS_API_KEY=your_obscuraworks_api_key_here
OBSCURAWORKS_BASE_URL=https://api.obscuraworks.com/v1

# Any model ID supported by the active provider can be used here.
AI_MODEL=your-model-id-here

# Flux AI Image Generation
# Default uses a Flux-compatible image endpoint. Replace if you have your own Flux endpoint.
FLUX_IMAGE_BASE_URL=https://image.myceli.ai/prompt
FLUX_IMAGE_MODEL=flux
FLUX_IMAGE_WIDTH=768
FLUX_IMAGE_HEIGHT=768

# Google Drive large file uploads
# Recommended for normal Gmail/My Drive: OAuth, so uploaded files use your own Drive quota.
GOOGLE_DRIVE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=your_refresh_token_here

# Fallback only for Shared Drives / Workspace setups. Service accounts do not have My Drive storage quota.
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_DRIVE_UPLOAD_MAX_MB=200
