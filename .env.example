# ==========================================
# Environment Variables Example (Local Run)
# ==========================================

# Database Configuration (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daikiweb

# Clerk Authentication Configuration
# Get these from your Clerk Dashboard (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Frontend Clerk Configuration (Must match CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Music Search / Full Song Playback (YouTube Data API v3)
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key_here
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/api/music/spotify/callback

# Optional Port Overrides (default backend: 5000, frontend: 5173)
PORT=5000
BASE_PATH=/
